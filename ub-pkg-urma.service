[Unit]
Description=The UnifiedBus Communication function of UB OS Component
Wants=network-online.target
After=sysinit.target
Before=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/ub-pkg-manager/bin/01-ub-pkg-urma.sh
StandardOutput=append:/var/log/ub-pkg-manager.log
StandardError=append:/var/log/ub-pkg-manager.log
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target